# =====================================================================
#  GRANTFLOW IPD — Variables d'environnement front (apps/web)
#  Copier en .env.local et remplir.
# =====================================================================

# --- next-auth ---
NEXTAUTH_URL=http://localhost:3000
# Générer un secret robuste : `openssl rand -base64 32`
NEXTAUTH_SECRET=dev-secret-change-me

# --- Keycloak ---
# Client `grantflow-web` du realm `grantflow` (cf. docs/keycloak-setup.md)
KEYCLOAK_ID=grantflow-web
KEYCLOAK_SECRET=dev-secret-from-keycloak
KEYCLOAK_ISSUER=http://localhost:8080/realms/grantflow

# --- API backend ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
