  closedBy       String?                 @map("closed_by") @db.Uuid
  reopenedAt     DateTime?               @map("reopened_at") @db.Timestamptz(6)
  reopenedBy     String?                 @map("reopened_by") @db.Uuid
  reopenReason   String?                 @map("reopen_reason")
  dedicatedFunds DedicatedFundMovement[]
  overheadCalcs  OverheadCalculation[]
  closer         AppUser?                @relation("FiscalPeriodClosedBy", fields: [closedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reopener       AppUser?                @relation("FiscalPeriodReopenedBy", fields: [reopenedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
