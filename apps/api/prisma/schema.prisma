  @@schema("procurement")
}

model Invoice {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceNumber   String         @map("invoice_number")
  supplierId      String         @map("supplier_id") @db.Uuid
  invoiceDate     DateTime       @map("invoice_date") @db.Date
  dueDate         DateTime       @map("due_date") @db.Date
  receivedAt      DateTime       @default(now()) @map("received_at") @db.Timestamptz(6)
  status          InvoiceStatus  @default(captured)
  totalHt         Decimal        @map("total_ht") @db.Decimal(18, 2)
  totalVat        Decimal        @default(0) @map("total_vat") @db.Decimal(18, 2)
  totalTtc        Decimal        @map("total_ttc") @db.Decimal(18, 2)
  currency        String         @default("XOF") @db.Char(3)
  exchangeRate    Decimal?       @map("exchange_rate") @db.Decimal(18, 8)
  poId            String?        @map("po_id") @db.Uuid
  ocrConfidence   Decimal?       @map("ocr_confidence") @db.Decimal(5, 2)
  pdfObjectKey    String?        @map("pdf_object_key")
  capturedPayload Json?          @map("captured_payload")
  rejectionReason String?        @map("rejection_reason")
  postedAt        DateTime?      @map("posted_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  matchedBy       String?        @map("matched_by") @db.Uuid
  matchedAt       DateTime?      @map("matched_at") @db.Timestamptz(6)
  matchSummary    Json?          @map("match_summary")
  total_ht_xof    BigInt?
  total_vat_xof   BigInt?
  total_ttc_xof   BigInt?
  fx_rate         Decimal?       @db.Decimal(14, 6)
  fx_rate_date    DateTime?      @db.Date
  matcher         AppUser?       @relation("InvoiceMatchedBy", fields: [matchedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  po              PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier        Supplier       @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines           InvoiceLine[]
  payments        Payment[]

  @@unique([supplierId, invoiceNumber])
  @@index([status], map: "idx_invoice_status")
  @@index([dueDate], map: "idx_invoice_due")
  @@index([poId], map: "idx_invoice_po")
  @@map("invoice")
  @@schema("ap")
}

model InvoiceLine {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId      String             @map("invoice_id") @db.Uuid
