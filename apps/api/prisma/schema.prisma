generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["ap", "audit", "auth", "co", "gl", "grant_office", "procurement", "ref", "reporting"]
}

model EventLog {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  occurredAt    DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  actorId       String?  @map("actor_id") @db.Uuid
  actorEmail    String?  @map("actor_email") @db.Citext
  action        String
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id") @db.Uuid
  payloadBefore Json?    @map("payload_before")
  payloadAfter  Json?    @map("payload_after")
  ipAddress     String?  @map("ip_address") @db.Inet
  userAgent     String?  @map("user_agent")
  result        String   @default("success")
  errorCode     String?  @map("error_code")
  requestId     String?  @map("request_id") @db.Uuid
  hashChain     String?  @map("hash_chain")

  @@index([entityType, entityId], map: "idx_audit_event_log_entity")
  @@index([actorId, occurredAt(sort: Desc)], map: "idx_audit_event_log_actor")
  @@index([requestId], map: "idx_audit_event_log_request_id")
  @@map("event_log")
  @@schema("audit")
}

model Role {
  id          String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  permissions RolePermission[]
  users       UserRole[]

  @@map("role")
  @@schema("auth")
}

model Permission {
  id     String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code   String           @unique
  label  String
  module String
  roles  RolePermission[]

  @@map("permission")
  @@schema("auth")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([roleId, permissionId])
  @@map("role_permission")
  @@schema("auth")
}

model AppUser {
  id                           String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                        String                @unique @db.Citext
  fullName                     String                @map("full_name")
  employeeCode                 String?               @map("employee_code")
  department                   String?
  status                       UserStatus            @default(active)
  mfaEnabled                   Boolean               @default(false) @map("mfa_enabled")
  lastLoginAt                  DateTime?             @map("last_login_at") @db.Timestamptz(6)
  createdAt                    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  invoicesMatched              Invoice[]             @relation("InvoiceMatchedBy")
  paymentRunsApproved          PaymentRun[]          @relation("PaymentRunApprover")
  paymentRunsPrepared          PaymentRun[]          @relation("PaymentRunPreparer")
  delegationsReceived          Delegation[]          @relation("DelegationDelegate")
  delegationsGiven             Delegation[]          @relation("DelegationDelegator")
  roles                        UserRole[]
  fiscalPeriodsClosed          FiscalPeriod[]        @relation("FiscalPeriodClosedBy")
  fiscalPeriodsReopened        FiscalPeriod[]        @relation("FiscalPeriodReopenedBy")
  journalEntriesPosted         JournalEntry[]
  periodCloseEvents            PeriodCloseEvent[]    @relation("PeriodCloseEventUser")
  notesTechniquesDrafted       NoteTechnique[]       @relation("NoteTechniqueDraftedBy")
  notesTechniquesValidated     NoteTechnique[]       @relation("NoteTechniqueValidatedBy")
  approvalSteps                ApprovalStep[]
  goodsReceiptsCancelled       GoodsReceipt[]        @relation("GrCancelledBy")
  goodsReceiptsCompleted       GoodsReceipt[]        @relation("GrCompletedBy")
  goodsReceiptsReceived        GoodsReceipt[]        @relation("GrReceivedBy")
  goodsReceiptsRejected        GoodsReceipt[]        @relation("GrRejectedBy")
  purchaseOrdersAsBuyer        PurchaseOrder[]
  prsRequested                 PurchaseRequest[]
  cashBoxesCustodian           CashBox[]
  cashSettlementsDone          CashSettlement[]
  projectsAsPi                 Project[]
  supplierIbanChanges          SupplierIbanHistory[] @relation("SupplierIbanHistoryChanger")
  donorReportsGenerated        DonorReport[]         @relation("DonorReportGeneratedBy")
  donorReportsLocked           DonorReport[]         @relation("DonorReportLockedBy")
  donorReportsSent             DonorReport[]         @relation("DonorReportSentBy")
  financialStatementsGenerated FinancialStatement[]  @relation("FinancialStatementGeneratedBy")
  financialStatementsLocked    FinancialStatement[]  @relation("FinancialStatementLockedBy")
  reportRunsGenerated          ReportRun[]

  @@index([status], map: "idx_user_status")
  @@map("app_user")
  @@schema("auth")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, roleId])
  @@map("user_role")
  @@schema("auth")
}

model Delegation {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  delegatorId String   @map("delegator_id") @db.Uuid
  delegateId  String   @map("delegate_id") @db.Uuid
  scope       Json
  validFrom   DateTime @map("valid_from") @db.Date
  validTo     DateTime @map("valid_to") @db.Date
  delegate    AppUser  @relation("DelegationDelegate", fields: [delegateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  delegator   AppUser  @relation("DelegationDelegator", fields: [delegatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("delegation")
  @@schema("auth")
}

model GlAccount {
  id                      String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                    String                @unique
  label                   String
  class                   String                @db.Char(1)
  parentCode              String?               @map("parent_code")
  isMovement              Boolean               @default(true) @map("is_movement")
  isActive                Boolean               @default(true) @map("is_active")
  syscebnlSpecific        Boolean               @default(false) @map("syscebnl_specific")
  description             String?
  invoiceLines            InvoiceLine[]
  allocationRulesAsSource AllocationRule[]
  journalLines            JournalLine[]
  prLinesAsDefault        PurchaseRequestLine[]
  bankAccounts            BankAccount[]
  budgetLinesAsDefault    BudgetLine[]
  taxCodes                TaxCode[]
  accountMappings         AccountMapping[]

  @@index([class], map: "idx_gl_account_class")
  @@map("gl_account")
  @@schema("ref")
}

model BankAccount {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code          String       @unique
  label         String
  accountNumber String       @map("account_number")
  bic           String?
  bankName      String       @map("bank_name")
  currency      String       @default("XOF") @db.Char(3)
  glAccountCode String       @map("gl_account")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  paymentRuns   PaymentRun[]
  glAccount     GlAccount    @relation(fields: [glAccountCode], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@index([currency], map: "idx_bank_account_currency")
  @@map("bank_account")
  @@schema("ref")
}

model AnalyticalAxis {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type              AxisType
  code              String
  label             String
  parentId          String?            @map("parent_id") @db.Uuid
  isActive          Boolean            @default(true) @map("is_active")
  metadata          Json?              @default("{}")
  allocationTargets AllocationTarget[]
  jlAsActivity      JournalLine[]      @relation("JlActivity")
  jlAsCostCenter    JournalLine[]      @relation("JlCostCenter")
  prsAsActivity     PurchaseRequest[]  @relation("PrActivity")
  prsAsCostCenter   PurchaseRequest[]  @relation("PrCostCenter")
  parent            AnalyticalAxis?    @relation("AxisHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children          AnalyticalAxis[]   @relation("AxisHierarchy")

  @@unique([type, code])
  @@index([type], map: "idx_axis_type")
  @@map("analytical_axis")
  @@schema("ref")
}

model Program {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String    @unique
  label       String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  projects    Project[]

  @@map("program")
  @@schema("ref")
}

model Project {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code              String             @unique
  title             String
  programId         String?            @map("program_id") @db.Uuid
  piUserId          String?            @map("pi_user_id") @db.Uuid
  startDate         DateTime           @map("start_date") @db.Date
  endDate           DateTime?          @map("end_date") @db.Date
  status            String             @default("active")
  description       String?
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  allocationTargets AllocationTarget[]
  journalLines      JournalLine[]
  purchaseRequests  PurchaseRequest[]
  grants            GrantAgreement[]
  pi                AppUser?           @relation(fields: [piUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program           Program?           @relation(fields: [programId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([piUserId], map: "idx_project_pi")
  @@map("project")
  @@schema("ref")
}

model Donor {
  id                   String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                 String                @unique
  label                String
  type                 DonorType
  country              String?
  contactEmail         String?               @map("contact_email") @db.Citext
  reportingTemplateId  String?               @map("reporting_template_id") @db.Uuid
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  grants               GrantAgreement[]
  donorReportTemplates DonorReportTemplate[]
  reportTemplates      ReportTemplate[]

  @@map("donor")
  @@schema("ref")
}

model GrantAgreement {
  id                String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference         String                  @unique
  donorId           String                  @map("donor_id") @db.Uuid
  projectId         String                  @map("project_id") @db.Uuid
  amount            Decimal                 @db.Decimal(18, 2)
  currency          String                  @db.Char(3)
  overheadRate      Decimal                 @default(0) @map("overhead_rate") @db.Decimal(6, 4)
  startDate         DateTime                @map("start_date") @db.Date
  endDate           DateTime                @map("end_date") @db.Date
  status            GrantStatus             @default(draft)
  signedAt          DateTime?               @map("signed_at") @db.Date
  notes             String?
  allowsCashPayment Boolean                 @default(true) @map("allows_cash_payment")
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  allocationTargets AllocationTarget[]
  dedicatedFunds    DedicatedFundMovement[]
  overheadCalcs     OverheadCalculation[]
  journalLines      JournalLine[]
  eligibilityRules  EligibilityRule[]
  notesTechniques   NoteTechnique[]
  purchaseRequests  PurchaseRequest[]
  budgetLines       BudgetLine[]
  donor             Donor                   @relation(fields: [donorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  donorReports      DonorReport[]
  reportRuns        ReportRun[]

  @@index([projectId], map: "idx_grant_project")
  @@index([donorId], map: "idx_grant_donor")
  @@map("grant_agreement")
  @@schema("ref")
}

model BudgetLine {
  id                       String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  grantId                  String                    @map("grant_id") @db.Uuid
  code                     String
  label                    String
  budgetedAmount           Decimal                   @map("budgeted_amount") @db.Decimal(18, 2)
  defaultAccount           String?                   @map("default_account")
  isOverheadEligible       Boolean                   @default(true) @map("is_overhead_eligible")
  isActive                 Boolean                   @default(true) @map("is_active")
  budgetedAmountXof        BigInt?                   @map("budgeted_amount_xof")
  fxRate                   Decimal?                  @map("fx_rate") @db.Decimal(14, 6)
  fxRateDate               DateTime?                 @map("fx_rate_date") @db.Date
  currency                 String?                   @db.VarChar(3)
  journalLines             JournalLine[]
  noteTechniqueBudgetLines NoteTechniqueBudgetLine[]
  purchaseOrderLines       PurchaseOrderLine[]
  purchaseRequestLines     PurchaseRequestLine[]
  defaultAccountRef        GlAccount?                @relation(fields: [defaultAccount], references: [code], onDelete: NoAction, onUpdate: NoAction)
  grant                    GrantAgreement            @relation(fields: [grantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([grantId, code])
  @@map("budget_line")
  @@schema("ref")
}

model Supplier {
  id               String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code             String                @unique
  name             String
  vatNumber        String?               @map("vat_number")
  address          String?
  country          String?
  iban             String?
  bic              String?
  bankName         String?               @map("bank_name")
  paymentTermsDays Int                   @default(30) @map("payment_terms_days")
  currencyDefault  String                @default("XOF") @map("currency_default") @db.Char(3)
  riskScore        Int?                  @default(0) @map("risk_score")
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  contactEmail     String?               @map("contact_email")
  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  ibanHistory      SupplierIbanHistory[]

  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_supplier_name_trgm", type: Gin)
  @@map("supplier")
  @@schema("ref")
}

/// Historique des changements d'IBAN fournisseur (sprint F4a — anti-fraude).
/// Une ligne « courante » par supplier (effective_to=NULL), garantie par index
/// partiel unique côté Postgres. Les anciennes lignes ont effective_to renseigné.
model SupplierIbanHistory {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  supplierId    String    @map("supplier_id") @db.Uuid
  iban          String?
  bic           String?
  bankName      String?   @map("bank_name")
  effectiveFrom DateTime  @default(now()) @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)
  changedBy     String?   @map("changed_by") @db.Uuid
  changeReason  String?   @map("change_reason")
  changer       AppUser?  @relation("SupplierIbanHistoryChanger", fields: [changedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([supplierId], map: "idx_supplier_iban_history_supplier")
  @@map("supplier_iban_history")
  @@schema("ref")
}

model ExchangeRate {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fromCurrency String   @map("from_currency") @db.Char(3)
  toCurrency   String   @map("to_currency") @db.Char(3)
  rate         Decimal  @db.Decimal(18, 8)
  rateDate     DateTime @map("rate_date") @db.Date
  source       String?
  isFixed      Boolean  @default(false) @map("is_fixed")

  @@unique([fromCurrency, toCurrency, rateDate])
  @@index([rateDate], map: "idx_exchange_rate_date")
  @@map("exchange_rate")
  @@schema("ref")
}

model TaxCode {
  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code               String              @unique
  label              String
  rate               Decimal             @db.Decimal(6, 4)
  accountCode        String?             @map("account_code")
  isActive           Boolean             @default(true) @map("is_active")
  invoiceLines       InvoiceLine[]
  purchaseOrderLines PurchaseOrderLine[]
  account            GlAccount?          @relation(fields: [accountCode], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@map("tax_code")
  @@schema("ref")
}

/// Caisse en espèces (petite caisse). Plafonds appliqués au service —
/// les CHECK protègent seulement les invariants positifs (cf. DDL §SPRINT 2.3).
model CashBox {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code             String            @unique
  label            String
  custodianUserId  String?           @map("custodian_user_id") @db.Uuid
  currency         String            @default("XOF") @db.Char(3)
  currentBalance   Decimal           @default(0) @map("current_balance") @db.Decimal(18, 2)
  ceiling          Decimal           @default(500000) @db.Decimal(18, 2)
  perRequestMax    Decimal           @default(100000) @map("per_request_max") @db.Decimal(18, 2)
  perDayUserMax    Decimal           @default(200000) @map("per_day_user_max") @db.Decimal(18, 2)
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  purchaseRequests PurchaseRequest[]
  custodian        AppUser?          @relation(fields: [custodianUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([isActive], map: "idx_cash_box_active")
  @@map("cash_box")
  @@schema("ref")
}

/// Régularisation d'une avance de mission (DA `cash_advance`). Une seule
/// entrée par DA (UNIQUE sur purchase_request_id côté DDL).
model CashSettlement {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purchaseRequestId String          @unique @map("purchase_request_id") @db.Uuid
  actualSpent       Decimal         @map("actual_spent") @db.Decimal(18, 2)
  variance          Decimal         @db.Decimal(18, 2)
  justifications    String?
  settledBy         String?         @map("settled_by") @db.Uuid
  settledAt         DateTime        @default(now()) @map("settled_at") @db.Timestamptz(6)
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  settler           AppUser?        @relation(fields: [settledBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchaseRequestId], map: "idx_cash_settlement_pr")
  @@map("cash_settlement")
  @@schema("ref")
}

model PurchaseRequest {
  id                       String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prNumber                 String                @unique @map("pr_number")
  requestedBy              String                @map("requested_by") @db.Uuid
  requestedAt              DateTime              @default(now()) @map("requested_at") @db.Timestamptz(6)
  neededBy                 DateTime?             @map("needed_by") @db.Date
  status                   PrStatus              @default(draft)
  projectId                String                @map("project_id") @db.Uuid
  grantId                  String                @map("grant_id") @db.Uuid
  costCenterId             String?               @map("cost_center_id") @db.Uuid
  activityId               String?               @map("activity_id") @db.Uuid
  totalAmount              Decimal               @default(0) @map("total_amount") @db.Decimal(18, 2)
  currency                 String                @default("XOF") @db.Char(3)
  description              String?
  requestType              PrType                @default(standard) @map("request_type")
  rejectionReason          String?               @map("rejection_reason")
  updatedAt                DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  cashBoxId                String?               @map("cash_box_id") @db.Uuid
  total_amount_xof         BigInt?
  fx_rate                  Decimal?              @db.Decimal(14, 6)
  fx_rate_date             DateTime?             @db.Date
  expenseNatureCode        String?               @map("expense_nature_code") @db.VarChar(64)
  pasteurParisReimbursed   Boolean               @default(false) @map("pasteur_paris_reimbursed")
  supplierInvoiceNumber    String?               @map("supplier_invoice_number") @db.VarChar(128)
  purchaseOrders           PurchaseOrder[]
  poLinks                  PurchaseOrderPr[]
  activity                 AnalyticalAxis?       @relation("PrActivity", fields: [activityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cashBox                  CashBox?              @relation(fields: [cashBoxId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  costCenter               AnalyticalAxis?       @relation("PrCostCenter", fields: [costCenterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grant                    GrantAgreement        @relation(fields: [grantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project                  Project               @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requester                AppUser               @relation(fields: [requestedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines                    PurchaseRequestLine[]
  cashSettlement           CashSettlement?

  @@index([status], map: "idx_pr_status")
  @@index([requestedBy], map: "idx_pr_requested_by")
  @@index([projectId], map: "idx_pr_project")
  @@index([requestType], map: "idx_pr_request_type")
  @@map("purchase_request")
  @@schema("procurement")
}

model PurchaseRequestLine {
  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prId               String              @map("pr_id") @db.Uuid
  lineNumber         Int                 @map("line_number")
  description        String
  quantity           Decimal             @db.Decimal(18, 4)
  unit               String              @default("unit")
  unitPrice          Decimal             @map("unit_price") @db.Decimal(18, 4)
  lineTotal          Decimal?            @default(dbgenerated("(quantity * unit_price)")) @map("line_total") @db.Decimal(18, 2)
  budgetLineId       String              @map("budget_line_id") @db.Uuid
  defaultAccount     String?             @map("default_account")
  unit_price_xof     BigInt?
  fx_rate            Decimal?            @db.Decimal(14, 6)
  fx_rate_date       DateTime?           @db.Date
  purchaseOrderLines PurchaseOrderLine[]
  budgetLine         BudgetLine          @relation(fields: [budgetLineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  defaultAccountRef  GlAccount?          @relation(fields: [defaultAccount], references: [code], onDelete: NoAction, onUpdate: NoAction)
  pr                 PurchaseRequest     @relation(fields: [prId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([prId, lineNumber])
  @@map("purchase_request_line")
  @@schema("procurement")
}

model ApprovalStep {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id") @db.Uuid
  stepOrder     Int       @map("step_order")
  approverId    String?   @map("approver_id") @db.Uuid
  approverRole  String?   @map("approver_role")
  status        String    @default("pending")
  decidedAt     DateTime? @map("decided_at") @db.Timestamptz(6)
  decisionNotes String?   @map("decision_notes")
  approver      AppUser?  @relation(fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entityType, entityId], map: "idx_approval_entity")
  @@map("approval_step")
  @@schema("procurement")
}

model PurchaseOrder {
  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  poNumber           String              @unique @map("po_number")
  prId               String?             @map("pr_id") @db.Uuid
  supplierId         String              @map("supplier_id") @db.Uuid
  orderDate          DateTime            @default(dbgenerated("CURRENT_DATE")) @map("order_date") @db.Date
  expectedDate       DateTime?           @map("expected_date") @db.Date
  status             PoStatus            @default(draft)
  totalHt            Decimal             @default(0) @map("total_ht") @db.Decimal(18, 2)
  totalVat           Decimal             @default(0) @map("total_vat") @db.Decimal(18, 2)
  totalTtc           Decimal             @default(0) @map("total_ttc") @db.Decimal(18, 2)
  currency           String              @default("XOF") @db.Char(3)
  incoterm           String?
  deliveryAddress    String?             @map("delivery_address")
  buyerId            String?             @map("buyer_id") @db.Uuid
  sentAt             DateTime?           @map("sent_at") @db.Timestamptz(6)
  acknowledgedAt     DateTime?           @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy     String?             @map("acknowledged_by")
  cancelledAt        DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason String?             @map("cancellation_reason")
  pdfObjectKey       String?             @map("pdf_object_key")
  emailSentAt        DateTime?           @map("email_sent_at") @db.Timestamptz(6)
  emailSentTo        String?             @map("email_sent_to")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  total_ht_xof       BigInt?
  total_vat_xof      BigInt?
  total_ttc_xof      BigInt?
  fx_rate            Decimal?            @db.Decimal(14, 6)
  fx_rate_date       DateTime?           @db.Date
  invoices           Invoice[]
  goodsReceipts      GoodsReceipt[]
  buyer              AppUser?            @relation(fields: [buyerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pr                 PurchaseRequest?    @relation(fields: [prId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines              PurchaseOrderLine[]
  prLinks            PurchaseOrderPr[]

  @@index([supplierId], map: "idx_po_supplier")
  @@index([status], map: "idx_po_status")
  @@map("purchase_order")
  @@schema("procurement")
}

/// Liaison N-N entre BC et DA (un BC peut consolider plusieurs DAs).
/// Voir DDL §SPRINT 3.
model PurchaseOrderPr {
  poId String          @map("po_id") @db.Uuid
  prId String          @map("pr_id") @db.Uuid
  po   PurchaseOrder   @relation(fields: [poId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pr   PurchaseRequest @relation(fields: [prId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([poId, prId])
  @@index([prId], map: "idx_po_pr_pr")
  @@map("purchase_order_pr")
  @@schema("procurement")
}

model PurchaseOrderLine {
  id                String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  poId              String               @map("po_id") @db.Uuid
  prLineId          String?              @map("pr_line_id") @db.Uuid
  lineNumber        Int                  @map("line_number")
  description       String
  quantity          Decimal              @db.Decimal(18, 4)
  quantityReceived  Decimal              @default(0) @map("quantity_received") @db.Decimal(18, 4)
  quantityInvoiced  Decimal              @default(0) @map("quantity_invoiced") @db.Decimal(18, 4)
  unit              String
  unitPrice         Decimal              @map("unit_price") @db.Decimal(18, 4)
  taxCodeId         String?              @map("tax_code_id") @db.Uuid
  lineTotal         Decimal?             @default(dbgenerated("(quantity * unit_price)")) @map("line_total") @db.Decimal(18, 2)
  budgetLineId      String               @map("budget_line_id") @db.Uuid
  unit_price_xof    BigInt?
  fx_rate           Decimal?             @db.Decimal(14, 6)
  fx_rate_date      DateTime?            @db.Date
  invoiceLines      InvoiceLine[]
  invoiceMatches    InvoiceMatch[]
  goodsReceiptLines GoodsReceiptLine[]
  budgetLine        BudgetLine           @relation(fields: [budgetLineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  po                PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  prLine            PurchaseRequestLine? @relation(fields: [prLineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taxCode           TaxCode?             @relation(fields: [taxCodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([poId, lineNumber])
  @@map("purchase_order_line")
  @@schema("procurement")
}

model GoodsReceipt {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  grNumber          String             @unique @map("gr_number")
  poId              String             @map("po_id") @db.Uuid
  receiptDate       DateTime           @default(dbgenerated("CURRENT_DATE")) @map("receipt_date") @db.Date
  receivedBy        String             @map("received_by") @db.Uuid
  status            GrStatus           @default(draft)
  deliveryNoteRef   String?            @map("delivery_note_ref")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  coldChainRequired Boolean            @default(false) @map("cold_chain_required")
  rejectedReason    String?            @map("rejected_reason")
  rejectedAt        DateTime?          @map("rejected_at") @db.Timestamptz(6)
  rejectedBy        String?            @map("rejected_by") @db.Uuid
  cancelledAt       DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  cancelledReason   String?            @map("cancelled_reason")
  cancelledBy       String?            @map("cancelled_by") @db.Uuid
  completedAt       DateTime?          @map("completed_at") @db.Timestamptz(6)
  completedBy       String?            @map("completed_by") @db.Uuid
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  canceller         AppUser?           @relation("GrCancelledBy", fields: [cancelledBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  completer         AppUser?           @relation("GrCompletedBy", fields: [completedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  po                PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receiver          AppUser            @relation("GrReceivedBy", fields: [receivedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejecter          AppUser?           @relation("GrRejectedBy", fields: [rejectedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
