model PaymentRun {
  id                  String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  runNumber           String       @unique @map("run_number")
  runDate             DateTime     @default(dbgenerated("CURRENT_DATE")) @map("run_date") @db.Date
  currency            String       @default("XOF") @db.Char(3)
  bankAccountId       String?      @map("bank_account_id") @db.Uuid
  preparedBy          String?      @map("prepared_by") @db.Uuid
  approvedBy          String?      @map("approved_by") @db.Uuid
  totalAmount         Decimal      @default(0) @map("total_amount") @db.Decimal(18, 2)
  status              String       @default("draft")
  sepaFileKey         String?      @map("sepa_file_key")
  preparationWarnings Json?        @map("preparation_warnings")
  rejectionReason     String?      @map("rejection_reason")
  approvedAt          DateTime?    @map("approved_at") @db.Timestamptz(6)
  executedAt          DateTime?    @map("executed_at") @db.Timestamptz(6)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Snapshot des alertes IBAN persistées au prepare (sprint F4a anti-fraude).
  ibanAlerts          Json?        @map("iban_alerts")
  /// XML pain.001.001.03 (sprint F4a, inline TEXT). Null tant que pas généré.
  sepaXml             String?      @map("sepa_xml")
  sepaGeneratedAt     DateTime?    @map("sepa_generated_at") @db.Timestamptz(6)
  sepaSentAt          DateTime?    @map("sepa_sent_at") @db.Timestamptz(6)
  payments            Payment[]
  approver            AppUser?     @relation("PaymentRunApprover", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bankAccount         BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  preparer            AppUser?     @relation("PaymentRunPreparer", fields: [preparedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_payment_run_status")
  @@map("payment_run")
  @@schema("ap")
}

model Payment {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  paymentRunId     String?       @map("payment_run_id") @db.Uuid
  invoiceId        String        @map("invoice_id") @db.Uuid
  amount           Decimal       @db.Decimal(18, 2)
  currency         String        @db.Char(3)
  method           PaymentMethod
  paymentDate      DateTime      @map("payment_date") @db.Date
  status           PaymentStatus @default(queued)
  bankReference    String?       @map("bank_reference")
  fxGainLoss       Decimal?      @default(0) @map("fx_gain_loss") @db.Decimal(18, 2)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Sprint F4a — multidevises : montant original en devise étrangère
  /// (ex EUR) si distinct de `currency` (devise du compte payeur, ex XOF).
  originalAmount   Decimal?      @map("original_amount") @db.Decimal(18, 2)
  originalCurrency String?       @map("original_currency") @db.Char(3)
  exchangeRate     Decimal?      @map("exchange_rate") @db.Decimal(18, 8)
  amount_xof       BigInt?
  fx_rate          Decimal?      @db.Decimal(14, 6)
  fx_rate_date     DateTime?     @db.Date
  invoice          Invoice       @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentRun       PaymentRun?   @relation(fields: [paymentRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceId], map: "idx_payment_invoice")
  @@index([status], map: "idx_payment_status")
  @@map("payment")
  @@schema("ap")
}

model FiscalPeriod {
