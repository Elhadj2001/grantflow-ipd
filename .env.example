# =====================================================================
#  GRANTFLOW IPD — Variables d'environnement (exemple)
#  Copier en .env et personnaliser
# =====================================================================

# ---- App ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# ---- PostgreSQL ----
# Host port: 5433 (Docker forwards 5433→container:5432). On garde 5433
# côté host pour cohabiter avec un éventuel Postgres natif déjà sur 5432.
# Voir docs/SETUP_WINDOWS.md §9 "Postgres natif" pour le détail.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=grantflow
POSTGRES_PASSWORD=grantflow
POSTGRES_DB=grantflow_dev
DATABASE_URL=postgresql://grantflow:grantflow@localhost:5433/grantflow_dev?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO (compatible S3) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_INVOICES=grantflow-invoices
MINIO_BUCKET_REPORTS=grantflow-reports

# ---- Keycloak (OIDC) ----
# Le secret DOIT correspondre à `clients[].secret` dans
# docker/keycloak/realm.json (champ "secret" du client grantflow-api).
# En cas de désynchro → 401 IDP.ADMIN_TOKEN_FAILED sur /admin/users.
# DEV : valeur cohérente entre les deux fichiers
# (`grantflow-api-dev-secret-2026`) ; PROD : secret rotaté via Vault.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=grantflow
KEYCLOAK_CLIENT_ID=grantflow-api
KEYCLOAK_CLIENT_SECRET=grantflow-api-dev-secret-2026

# ---- Keycloak Admin API (sprint F-ADMIN-USERS) ----
# Le service account du client `grantflow-api` consomme l'Admin REST de
# Keycloak pour créer/désactiver des comptes + assigner des realm roles.
#
# Pré-requis CRITIQUES (tous réalisés dans docker/keycloak/realm.json) :
#   1. clients[].bearerOnly = FALSE pour ce client. Un bearer-only client
#      NE PEUT PAS demander de token client_credentials (Keycloak refuse :
#      400 "Bearer-only not allowed"). On a donc bearerOnly=false +
#      serviceAccountsEnabled=true + directAccessGrantsEnabled=true.
#   2. Le service account (`service-account-grantflow-api`) doit porter
#      les rôles client `realm-management` : view-users, query-users,
#      manage-users, view-realm. Sans ça, 403 sur l'Admin REST.
#   3. smtpServer configuré (DEV = MailHog sur container "mailhog:1025")
#      pour que `sendResetPasswordEmail` (UPDATE_PASSWORD) fonctionne.
#
# On réutilise les variables ci-dessus (KEYCLOAK_URL + REALM + CLIENT_ID +
# CLIENT_SECRET) — le même client gère l'auth bearer et l'admin (lui-même
# protégé par client_credentials). Pas de variable supplémentaire à
# définir, mais ne JAMAIS committer un vrai secret : utiliser le secret
# manager (Vault / Doppler / GitHub Actions secrets) en prod.

# ---- Logout fédéré OIDC (sprint F-LOGOUT) ----
# Le bouton "Se déconnecter" et l'auto-logout 401 redirigent désormais vers
# /api/auth/federated-logout : ce route handler tue la session next-auth
# ET la session SSO Keycloak (RP-Initiated Logout avec id_token_hint).
# Le prochain /api/auth/signin REDEMANDE identifiants.
#
# Opt-in (DEV recommandé pour tests multi-profils) : si KEYCLOAK_FORCE_
# LOGIN_PROMPT=true, on ajoute prompt=login aux paramètres OIDC — Keycloak
# affiche TOUJOURS l'écran de saisie, même sans logout préalable. Par
# défaut désactivé (= SSO standard) en prod.
KEYCLOAK_FORCE_LOGIN_PROMPT=false

# ---- JWT ----
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=8h

# ---- Mistral / IA ----
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OPENAI_API_KEY=

# ---- OCR (sprint F-OCR-VISION) ----
# Le module Invoicing supporte 2 providers OCR :
#   - `pdfparse` (DÉFAUT) : extraction texte natif via pdf-parse — local,
#     0 coût, 0 PII envoyée à un tiers. Suffisant pour les factures
#     numériques (Sage, EBP, Odoo…). Échoue sur les PDF scannés (image).
#   - `vision` (OPT-IN)   : appel à l'API Anthropic Claude Vision pour les
#     factures scannées / pas de couche texte. ⚠ Envoie le PDF à un tiers.
#   - `auto`              : `pdfparse` d'abord, bascule sur `vision` si
#     `isImageScan` ou si la confiance est < OCR_VISION_FALLBACK_THRESHOLD.
#
# ⚠ CONFIDENTIALITÉ — Activer Vision uniquement après revue DPO/IT
# (les factures peuvent contenir des données personnelles fournisseur).
# La clé API doit venir d'un secret manager en prod (Vault/Doppler).
# Ne JAMAIS committer ANTHROPIC_API_KEY dans le repo.
OCR_PROVIDER=pdfparse
ANTHROPIC_API_KEY=
# Modèle Claude utilisé en mode vision. Laisser vide = défaut interne
# (modèle Claude récent de classe Sonnet). Ne PAS hardcoder un ID
# spécifique en prod sans plan de mise à jour.
OCR_VISION_MODEL=
# Seuil (0-100) en mode `auto` : si la confiance pdf-parse est inférieure
# OU si isImageScan=true, on bascule sur Vision (si activé).
OCR_VISION_FALLBACK_THRESHOLD=50
# Taille max du PDF envoyé à Vision (en octets). Défaut : 5 Mo.
OCR_VISION_MAX_BYTES=5242880

# ---- Mail (dev = MailHog) ----
# Le service MailService (Nest) est utilisé pour :
#   - Sprint F-PO-EMAIL : envoi automatique du PDF du Bon de Commande au
#     fournisseur à la transition `sent` (BEST-EFFORT : ne bloque jamais
#     l'engagement comptable classe 8 si SMTP est down). UI MailHog en
#     dev : http://localhost:8025 ; le port SMTP local est 1025.
#   - Notifications Keycloak (UPDATE_PASSWORD via Admin REST), reset
#     password, etc.
#
# DEV  : SMTP_HOST=localhost SMTP_PORT=1025 (MailHog)
# PROD : SMTP_HOST=smtp.example.org SMTP_PORT=587 + auth + SMTP_SECURE=true
#        (jamais committer un vrai SMTP_PASS — utiliser un secret manager)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=true en prod (TLS implicite via port 465 ou STARTTLS sur 587)
SMTP_SECURE=false
MAIL_FROM="GRANTFLOW IPD <no-reply@pasteur.sn>"

# ---- Misc ----
TIMEZONE=Africa/Dakar
DEFAULT_CURRENCY=XOF
DEFAULT_LOCALE=fr
