# =====================================================================
#  GRANTFLOW IPD — Variables d'environnement (exemple)
#  Copier en .env et personnaliser
# =====================================================================

# ---- App ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=grantflow
POSTGRES_PASSWORD=grantflow
POSTGRES_DB=grantflow_dev
DATABASE_URL=postgresql://grantflow:grantflow@localhost:5432/grantflow_dev?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO (compatible S3) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_INVOICES=grantflow-invoices
MINIO_BUCKET_REPORTS=grantflow-reports

# ---- Keycloak (OIDC) ----
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=grantflow
KEYCLOAK_CLIENT_ID=grantflow-api
KEYCLOAK_CLIENT_SECRET=changeme

# ---- JWT ----
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=8h

# ---- Mistral / IA ----
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OPENAI_API_KEY=

# ---- Mail (dev = MailHog) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GRANTFLOW IPD <no-reply@pasteur.sn>"

# ---- Misc ----
TIMEZONE=Africa/Dakar
DEFAULT_CURRENCY=XOF
DEFAULT_LOCALE=fr
